<Window x:Class="FarmManager.App.Views.Employees.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Employees"
        xmlns:vm="clr-namespace:FarmManager.App.ViewModels.Employees"
        xmlns:app="clr-namespace:FarmManager.App.Helpers"
        mc:Ignorable="d"
        Language="pl-PL"
        Title="Edycja pracownika" Height="1080" Width="775"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding EmployeeEditViewModel, Source={StaticResource Locator}}">
    <Grid>
        <!-- FirstName -->
        <Button Margin="30,30,0,0" Width="Auto" Height="40" Content="Imię" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,80,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,80,0,0" Width="680" Height="60"
             Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="50" 
             VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" 
             HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
             BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- LastName -->
        <Button Margin="30,150,0,0" Width="Auto" Height="40" Content="Nazwisko" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,200,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,200,0,0" Width="680" Height="60" 
             Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="50" 
             VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" 
             HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
             BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- IdNumber -->
        <Button Margin="30,270,0,0" Width="Auto" Height="40" Content="Nr dowodu" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,320,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,320,0,0" Width="680" Height="60" 
             Text="{Binding IdNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="9" 
             VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" 
             HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
             BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- PhoneNumber -->
        <Button Margin="30,390,0,0" Width="Auto" Height="40" Content="Telefon" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,440,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,440,0,0" Width="680" Height="60" 
             Text="{Binding PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="14" 
             VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" 
             HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
             BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- Email -->
        <Button Margin="30,510,0,0" Width="Auto" Height="40" Content="Email" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,560,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,560,40,0" Height="60" Width="680"
             Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
             FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="50" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- BaseRent -->
        <Button Margin="30,630,0,0" Width="Auto" Height="40" Content="Cena za wypożyczenie" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,680,0,0" Width="700" Height="60" IsEnabled="False" Opacity="1" 
            VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" 
            BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,680,0,0" Width="680" Height="60" 
            Text="{Binding BaseRent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" app:NumericTextBoxBehaviorHelper.IsNumericOnly="True"
            FontWeight="Medium" app:SelectAllOnFocus.Enable="True" 
            VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" 
            HorizontalContentAlignment="Left" VerticalContentAlignment="Center" 
            BorderThickness="0" FontSize="30" Foreground="Black"/>

        <!-- IsRentable -->
        <Button Margin="30,750,0,0" Width="Auto" Height="40" Content="Z wypożyczalni" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <ToggleButton Margin="30,800,0,0" Height="40" Width="80" 
                  IsChecked="{Binding IsRentable, Mode=TwoWay}" 
                  HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- IsActive -->
        <Button Margin="30,850,0,0" Width="Auto" Height="40" Content="Aktywność" Opacity="1" 
            IsEnabled="False" VerticalAlignment="Top" Background="White" 
            HorizontalAlignment="Left" BorderThickness="2" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <ToggleButton Margin="30,900,0,0" Height="40" Width="80" 
                  IsChecked="{Binding IsActive, Mode=TwoWay}" 
                  HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- Action buttons -->
        <Button Margin="30,0,0,30" Width="180" Height="60" Content="Usuń" 
            Command="{Binding Delete}" Background="#FFFF5454" BorderBrush="#FFFF5454" 
            Focusable="False" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
            Grid.Row="4" IsDefault="True" materialDesign:ButtonAssist.CornerRadius="10" 
            FontSize="20" Foreground="{DynamicResource MaterialDesignBody}"/>
        <Button Margin="0,0,30,30" Width="180" Height="60" Content="Zapisz" 
            Command="{Binding Update}" Focusable="False" VerticalAlignment="Bottom" 
            HorizontalAlignment="Right" Grid.Row="4" IsDefault="True" 
            materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" 
            Foreground="{DynamicResource MaterialDesignBody}"/>
    </Grid>
</Window>
