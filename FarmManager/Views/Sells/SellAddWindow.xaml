<Window x:Class="FarmManager.App.Views.Sells.SellAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Sells"
        Language="pl-PL"
        xmlns:app="clr-namespace:FarmManager.App.Helpers"
        mc:Ignorable="d"
        Title="Dodawanie sprzedaży" Height="650" Width="1110"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding SellAddViewModel, Source={StaticResource Locator}}">
    <Window.Resources>
        <app:DateOnlyToDateTimeConverter x:Key="DtoToDtConverter"/>
    </Window.Resources>
    <Grid>
        <Button Margin="30,30,0,0" Width="Auto" Height="40" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Nazwa rośliny"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,80,0,0" Width="500" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,80,0,0" Width="480" IsReadOnly="True" IsTabStop="True" app:FocusCommandBehavior.Command="{Binding OpenPlant}" Height="60" Text="{Binding Plant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,80,0,0" IsReadOnly="True" IsTabStop="True" Width="0" Height="0"/>

        <Button Margin="30,150,0,0" Width="Auto" Height="40" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Nazwa kupca"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,200,0,0" Width="500" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,200,0,0" Width="480" IsReadOnly="True" IsTabStop="True" app:FocusCommandBehavior.Command="{Binding OpenDeposit}" Height="60" Text="{Binding Deposit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="30,270,0,0" Width="Auto" Height="40" Opacity="1" IsEnabled="False" VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Ilość - kg"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,320,0,0" Width="500" Height="60" IsEnabled="False" Opacity="1" VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,320,0,0" Width="480" Height="60" Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" app:NumericTextBoxBehaviorHelper.IsNumericOnly="True" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="30,390,0,0" Width="Auto" Height="40" Opacity="1" IsEnabled="False" VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Cena całościowa - zł"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,440,0,0" Width="500" Height="60" IsEnabled="False" Opacity="1" VerticalAlignment="Top" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,440,0,0" Width="480" Height="60" Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" app:NumericTextBoxBehaviorHelper.IsNumericOnly="True" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="560,30,0,0" Width="Auto" Height="40" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Data"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="560,80,0,0" Width="500" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <DatePicker Margin="570,80,0,0" Width="480" Height="60" SelectedDate="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DtoToDtConverter}}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black" FirstDayOfWeek="Monday" />

        <Button Margin="560,150,0,0" Width="Auto" Height="40" Content="Opis" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="560,200,0,0" Width="500" Height="180" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="570,200,0,0" Width="480" Height="180" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="100" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="0,0,30,30" Width="180" Height="60" Content="Dodaj" Command="{Binding Add}" Focusable="False" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsDefault="True" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="{DynamicResource MaterialDesignBody}"/>
    </Grid>
</Window>

