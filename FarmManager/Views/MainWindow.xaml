<Window x:Class="FarmManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager"
        xmlns:vm="clr-namespace:FarmManager.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowName}" Height="430" Width="600"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Menu>
            <MenuItem Header="Sprzedawcy" FontSize="20">
                <MenuItem Header="Dodaj sprzedawcę" Command="{Binding AddDeposit}" FontSize="20" />
            </MenuItem>
        </Menu>
        <!--Buttons are used for better visual aspect-->
        <Button IsEnabled="False" Opacity="1" Content="{Binding WindowName}" Background="White" HorizontalAlignment="Left" Margin="50,100,0,0" VerticalAlignment="Top" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" Width="500" Height="40" FontSize="20" Foreground="Black"/>
        <Button IsEnabled="False" Opacity="1" Height="160" Width="500" Background="White" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin="50,150,0,0" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox FontWeight="Medium" IsReadOnly="True" TextWrapping="Wrap" Grid.RowSpan="3" Height="160" Text="Zacznij swoją naukę języka od postawowych słowników i rozszerzaj swoje słownictwo tworząc własne." Width="480" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalAlignment="Top" VerticalContentAlignment="Center" Margin="60,150,0,0" BorderThickness="0" FontSize="28" Foreground="Black"/>
    </Grid>
</Window>
