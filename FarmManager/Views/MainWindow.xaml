<Window x:Class="FarmManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager"
        xmlns:vm="clr-namespace:FarmManager.App.ViewModels"
        mc:Ignorable="d"
        Title="RolnikPro" Height="430" Width="600"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding MainWindowViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Menu>
            <MenuItem Header="Praca" FontSize="20">
                <MenuItem Header="Dni" Command="{Binding Workdays}" FontSize="20" />
            </MenuItem>
            <MenuItem Header="Zaawansowane" FontSize="20">
                <MenuItem Header="Rośliny" Command="{Binding Plants}" FontSize="20" />
                <MenuItem Header="Sezony" Command="{Binding Seasons}" FontSize="20" />
                <MenuItem Header="Zakupy" Command="{Binding Buys}" FontSize="20" />
                <MenuItem Header="Pryskania" Command="{Binding Sprayings}" FontSize="20" />
                <MenuItem Header="Pożyczki pracowników" Command="{Binding EmployeeCosts}" FontSize="20" />
            </MenuItem>
            <MenuItem Header="Podstawowe" FontSize="20">
                <MenuItem Header="Kupcy" Command="{Binding Deposits}" FontSize="20" />
                <MenuItem Header="Choroby" Command="{Binding Diseases}" FontSize="20" />
                <MenuItem Header="Pracownicy" Command="{Binding Employees}" FontSize="20" />
                <MenuItem Header="Nawozy" Command="{Binding Fertilizers}" FontSize="20" />
                <MenuItem Header="Odmiany" Command="{Binding Varieties}" FontSize="20" />
                <MenuItem Header="Sprzedawcy" Command="{Binding Vendors}" FontSize="20" />
                <MenuItem Header="Czynności" Command="{Binding Actions}" FontSize="20" />
            </MenuItem>
        </Menu>
        <Button IsEnabled="False" Opacity="1" Content="RolnikPro" Background="White" HorizontalAlignment="Left" Margin="50,100,0,0" VerticalAlignment="Top" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" Width="500" Height="40" FontSize="20" Foreground="Black"/>
        <Button IsEnabled="False" Opacity="1" Height="180" Width="500" Background="White" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin="50,150,0,0" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox FontWeight="Medium" IsReadOnly="True" TextWrapping="Wrap" Grid.RowSpan="3" Height="180" Text="Zobacz, jak Twoja praca przekłada się na realne wyniki. Śledź plony i porównuj je z kosztami produkcji. Podejmuj decyzje oparte na faktach, nie domysłach." Width="480" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalAlignment="Top" VerticalContentAlignment="Center" Margin="60,150,0,0" BorderThickness="0" FontSize="28" Foreground="Black"/>
    </Grid>
</Window>
