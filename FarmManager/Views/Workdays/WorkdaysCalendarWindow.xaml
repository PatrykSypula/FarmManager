<Window x:Class="FarmManager.App.Views.Workdays.WorkdaysCalendarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Workdays"
        mc:Ignorable="d"
        xmlns:app="clr-namespace:FarmManager.App.Helpers"
        Title="Dodawanie sprzedawcy" Height="720" Width="1280"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding WorkdaysCalendarViewModel, Source={StaticResource Locator}}">
    <Window.Resources>
        <app:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with navigation -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Margin="1" Width="Auto" Height="40" Content="Poprzedni miesiąc" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black" Command="{Binding PreviousMonth}"/>
            <Button Margin="1" Width="Auto" Height="40" Content="{Binding CurrentMonthName}" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black" Command="{Binding CurrentMonth}"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Następny miesiąc" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black" Command="{Binding NextMonth}"/>
        </StackPanel>

        <!-- Weekday headers -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="7">
            <Button Margin="1" Width="Auto" Height="40" Content="Poniedziałek" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Wtorek" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Środa" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Czwartek" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Piątek" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Sobota" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
            <Button Margin="1" Width="Auto" Height="40" Content="Niedziela" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Stretch" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        </UniformGrid>

        <!-- Days grid -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days}"
                      HorizontalContentAlignment="Stretch" 
                      VerticalContentAlignment="Stretch">
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="{Binding Rows}" Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Padding="0"
                            Height="Auto" Width="Auto" 
                            Margin="1"
                            Command="{Binding DataContext.DayClick, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding Date}"
                            Background="White"
                            BorderThickness="2"
                            Foreground="Black"
                            materialDesign:ButtonAssist.CornerRadius="10">

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <!-- Days not in current month appear gray -->
                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                        <Setter Property="Foreground" Value="LightGray"/>
                                        <Setter Property="BorderBrush" Value="LightGray"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>

                                    <!-- Hover effect -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0E8FF"/>
                                    </Trigger>

                                    <!-- Pressed effect -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#90C8FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Grid IsHitTestVisible="False">
                            <!-- Events -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                          HorizontalScrollBarVisibility="Disabled"
                                          Margin="2,28,2,2"
                                          Background="Transparent">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding Events}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="2" Padding="4" CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="LightGreen"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                                                    <Setter Property="Background" Value="Yellow"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Text}" FontSize="13" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Day number -->
                            <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM}}"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,6,8,0"
                                IsHitTestVisible="False"/>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
