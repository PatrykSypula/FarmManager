<Window x:Class="FarmManager.App.Views.Workdays.WorkdaysHourly.WorkdayHarvestHourlyAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Workdays.WorkdaysHourly"
        mc:Ignorable="d"
        Language="pl-PL"
        xmlns:app="clr-namespace:FarmManager.App.Helpers"
        Title="Dodawanie dnia pracy - zbiór na godziny" Height="720" Width="1310"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding WorkdayHarvestHourlyAddViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Button Margin="30,30,0,0" Width="Auto" Height="40" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Nazwa rośliny"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,80,0,0" Width="500" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,80,0,0" Width="480" IsReadOnly="True" IsTabStop="True" app:FocusCommandBehavior.Command="{Binding OpenPlant}" Height="60" Text="{Binding Plant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="30,150,0,0" Width="Auto" Height="40" Content="Opis" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,200,0,0" Width="500" Height="120" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,200,0,0" Width="480" Height="120" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" MaxLength="100" TextWrapping="Wrap" VerticalAlignment="Top" Grid.RowSpan="3" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" BorderThickness="0" FontSize="30" Foreground="Black"/>

        
        <Button Margin="30,330,0,0" Width="Auto" Height="40" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black">
            <TextBlock>
            <Run Text="Zbiór - kg"/>
            <Run Text="*" Foreground="Red"/>
            </TextBlock>
        </Button>
        <Button Margin="30,380,0,0" Width="500" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,380,0,0" Width="480" Height="60" Text="{Binding HourlyQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" app:NumericTextBoxBehaviorHelper.IsNumericOnly="True" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Margin="560,30,45,0" Width="700" Height="470">
            <DataGrid FontSize="20" VerticalAlignment="Top" SelectedItem="{Binding SelectedWorkdayHourly, Mode=TwoWay}" CanUserAddRows="False" IsReadOnly="True" AutoGenerateColumns="False" ItemsSource="{Binding WorkdaysHourly}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Imię" Width="*" Binding="{Binding Employee.FirstName}"/>
                    <DataGridTextColumn Header="Ksywka" Width="*" Binding="{Binding Employee.Nickname}"/>
                    <DataGridTextColumn Header="Nazwisko" Width="*" Binding="{Binding Employee.LastName}"/>
                    <DataGridTextColumn Header="Godziny" Width="*" Binding="{Binding Hours}"/>
                    <DataGridTextColumn Header="Stawka" Width="*" Binding="{Binding Price}"/>
                </DataGrid.Columns>
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenWorkdayHourlyEdit}"/>
                </DataGrid.InputBindings>
            </DataGrid>
        </Grid>

        <Button Margin="560,510,30,30" Width="340" Height="60" Content="Dodaj wszystkich" Command="{Binding OpenWorkdayHourlyAddAll}" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="920,510,30,30" Width="340" Height="60" Content="Dodaj pracownika" Command="{Binding OpenWorkdayHourlyAddOne}" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>

        <Button Margin="0,0,30,30" Width="180" Height="60" Content="Dodaj" Command="{Binding Add}" Focusable="False" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsDefault="True" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="{DynamicResource MaterialDesignBody}"/>
    </Grid>
</Window>
