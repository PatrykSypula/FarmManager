<Window x:Class="FarmManager.App.Views.Workdays.WorkdaysCollecting.WorkdayCollectingAddAllWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Workdays.WorkdaysCollecting"
        xmlns:app="clr-namespace:FarmManager.App.Helpers"
        mc:Ignorable="d"
        Language="pl-PL"
        Title="Dodawanie pracy" Height="290" Width="515"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding WorkdayCollectingAddAllViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Button Margin="30,30,0,0" Width="Auto" Height="40" Content="Stawka za kg" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>
        <Button Margin="30,80,0,0" Width="440" Height="60" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <TextBox Margin="40,80,0,0" Width="420" Height="60" Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" app:NumericTextBoxBehaviorHelper.IsNumericOnly="True" FontWeight="Medium" app:SelectAllOnFocus.Enable="True" VerticalAlignment="Top" Background="Transparent" HorizontalAlignment="Left" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" BorderThickness="0" FontSize="30" Foreground="Black"/>

        <Button Margin="0,0,30,30" Width="180" Height="60" Content="Dodaj" Command="{Binding Add}" Focusable="False" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsDefault="True" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="{DynamicResource MaterialDesignBody}"/>
    </Grid>
</Window>
