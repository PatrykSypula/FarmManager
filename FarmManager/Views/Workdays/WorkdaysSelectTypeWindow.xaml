<Window x:Class="FarmManager.App.Views.Workdays.WorkdaysSelectTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmManager.App.Views.Workdays"
                xmlns:app="clr-namespace:FarmManager.App.Helpers"
        Language="pl-PL"
        mc:Ignorable="d"
        Title="Wybór typu pracy" Height="350" Width="515"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding WorkdaysSelectTypeViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Button Margin="30,30,0,0" Width="Auto" Height="40" Content="Wybierz typ pracy" IsEnabled="False" VerticalAlignment="Top" Opacity="1" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="20" Foreground="Black"/>

        <Button Margin="30,80,0,0" Width="440" Height="60" Command="{Binding SelectHourlyWork}" VerticalAlignment="Top" Content="Praca godzinowa" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <Button Margin="30,150,0,0" Width="440" Height="60" Command="{Binding SelectHarvestHourly}" VerticalAlignment="Top" Content="Zbiór na godziny" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        <Button Margin="30,220,0,0" Width="440" Height="60" Command="{Binding SelectHarvestCollecting}" VerticalAlignment="Top" Content="Zbiór na kilogramy" Opacity="1" Grid.RowSpan="3" Background="White" HorizontalAlignment="Left" BorderThickness="2" materialDesign:ButtonAssist.CornerRadius="10" FontSize="30" Foreground="Black"/>
        
    </Grid>
</Window>
